{
  "attribution": {
    "commit": "",
    "pr": ""
  },
  "permissions": {
    "allow": [
      "Bash(find:*)",
      "Bash(grep:*)",
      "Bash(jq:*)",
      "Bash(ls:*)",
      "Bash(rg:*)",
      "Bash(dev:*)",
      "Bash(pnpm:*)",
      "Bash(shadowenv exec -- pnpm:*)"
    ],
    "deny": [],
    "defaultMode": "dontAsk"
  },
  "hooks": {
    "SessionStart": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "/Users/kieran/.config/claude/hooks/skills-update.mjs",
            "timeout": 10000
          }
        ]
      }
    ],
    "Notification": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "/Users/kieran/.config/claude/hooks/agent-state-tmux.sh needs-input claude"
          }
        ]
      }
    ],
    "Stop": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "/Users/kieran/.config/claude/hooks/agent-state-tmux.sh done claude"
          }
        ]
      }
    ]
  },
  "skipDangerousModePermissionPrompt": true,
  "model": "opus",
  "enabledPlugins": {},
  "effortLevel": "high"
}
