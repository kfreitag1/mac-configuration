// Zed settings
//
// For information on how to configure Zed, see the Zed
// documentation: https://zed.dev/docs/configuring-zed
//
// To see all of Zed's default settings without changing your
// custom settings, run `zed: open default settings` from the
// command palette (cmd-shift-p / ctrl-shift-p)
{
  "diff_view_style": "unified",
  "cli_default_open_behavior": "new_window",
  "project_panel": {
    "dock": "left",
  },
  "outline_panel": {
    "dock": "left",
  },
  "collaboration_panel": {
    "dock": "right",
  },
  "git_panel": {
    "dock": "left",
  },
  "lsp": {
    "rubocop": {
      // RuboCop's native language server (`rubocop --lsp`) for formatting and
      // lint autocorrect on save. The launcher routes through the zone's
      // shadowenv + bundle so it loads the project's .rubocop.yml, custom cops,
      // and plugins (rubocop-sorbet, rubocop-rails, ...).
      // Source: zed/bin/rubocop-launcher in this dotfiles repo, stowed here.
      "binary": {
        "path": "/Users/kieran/.config/zed/bin/rubocop-launcher",
        "arguments": [],
      },
    },
    "sorbet": {
      // Sorbet LSP via a launcher that locates the sorbet binary inside the
      // zone's bundle and execs it directly with --lsp. Only does anything if
      // a `sorbet/config` exists at or above the project root — otherwise
      // exits cleanly and Zed disables it for the session. Provides hover /
      // completion / go-to-def for everything, incl. Rails model columns &
      // associations via Tapioca's generated sorbet/rbi/dsl/** RBIs.
      "binary": {
        "path": "/Users/kieran/.config/zed/bin/sorbet-launcher",
        "arguments": [],
      },
    },
    "vtsls": {
      "settings": {
        "typescript": {
          "updateImportsOnFileMove": {
            "enabled": "always",
          },
        },
        "javascript": {
          "updateImportsOnFileMove": {
            "enabled": "always",
          },
        },
      },
      "enable_lsp_tasks": true,
    },
  },
  "when_closing_with_no_tabs": "keep_window_open",
  "soft_wrap": "editor_width",
  // "auto_signature_help": true,
  "agent_servers": {
    "claude-acp": {
      "type": "registry",
      "default_config_options": {
        "mode": "bypassPermissions",
      },
    },
  },
  "agent": {
    // "dock": "left",
    "dock": "right",
    "play_sound_when_agent_done": "when_hidden",
    "model_parameters": [],
  },
  "show_signature_help_after_edits": true,
  "show_completions_on_input": true,
  "use_on_type_format": false,
  "formatter": "prettier",
  "languages": {
    "Ruby": {
      // sorbet: types, hover, go-to-def, completion — incl. Rails model columns
      //   & associations via Tapioca's generated sorbet/rbi/dsl/** RBIs.
      // rubocop: formatting + lint autocorrect on save (pinned as formatter
      //   below, since sorbet doesn't format).
      "language_servers": [
        "sorbet",
        "rubocop",
        "!ruby-lsp",
        "!solargraph",
        "!steep",
        "!kanayago",
      ],
      "formatter": { "language_server": { "name": "rubocop" } },
      "format_on_save": "on",
      "tab_size": 2,
    },
  },
  "file_scan_exclusions": [
    // "**/.git",
    // "**/.svn",
    // "**/.hg",
    // "**/.jj",
    "**/CVS",
    "**/.DS_Store",
    "**/Thumbs.db",
    "**/.classpath",
    "**/.settings",
  ],
  "format_on_save": "on",
  "terminal": {
    "dock": "right",
  },
  "ui_font_weight": 350.0,
  "ssh_connections": [
    {
      "host": "home.kfreitag.ca",
      "args": [],
      "projects": [
        {
          "paths": ["/home/kieran"],
        },
      ],
    },
  ],
  "use_system_path_prompts": false,
  "vertical_scroll_margin": 12,
  "relative_line_numbers": "enabled",
  "disable_ai": false,
  "buffer_font_family": "JetBrainsMonoNL Nerd Font Mono",
  "telemetry": {
    "diagnostics": true,
    "metrics": true,
  },
  "active_pane_modifiers": {
    "border_size": 1,
  },
  "vim_mode": true,
  "icon_theme": {
    "mode": "dark",
    "light": "Zed (Default)",
    "dark": "Zed (Default)",
  },
  "ui_font_size": 15.0,
  "buffer_font_size": 13.0,
  "theme": {
    "mode": "dark",
    "light": "One Light",
    "dark": "Catppuccin Mocha - No Italics",
  },
  "theme_overrides": {
    "Catppuccin Mocha - No Italics": {
      "border.transparent": "#00000000",
      "border.variant": "#2e2f3e",
    },
  },
}
